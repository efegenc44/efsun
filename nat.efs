module Main


let main = \a
    mul (Succ (Succ Zero)) (Succ (Succ (Succ Zero)))

structure Pair[a b]
    | Pair a b

import Main.Pair.Pair

structure Nat
    | Zero
    | Succ Nat

import Main.Nat (Zero Succ)

let add = \n \m match Pair n m
    | Pair ~a Zero      = a
    | Pair ~a (Succ ~b) = Succ (add a b)

let mul = \n \m match Pair n m
    | Pair ~a Zero      = Zero
    | Pair ~a (Succ ~b) = add a (mul a b)